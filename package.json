{
  "name": "marginalia",
  "version": "1.0.0",
  "private": true,
  "description": "A grounded literature analysis desk: upload papers, get summaries, research gaps, a literature matrix, themes, critical appraisal, topic suggestions, and a paper-finder — answered only from what you upload.",
  "type": "commonjs",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "desktop:build": "npm run build && electron-builder --mac",
    "desktop:start": "npm run build && electron ."
  },
  "dependencies": {
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.1"
  },
  "build": {
    "appId": "com.marginalia.researchdesk",
    "productName": "Marginalia",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": ["dmg"]
    }
  },
  "engines": {
    "node": ">=18"
  }
}
